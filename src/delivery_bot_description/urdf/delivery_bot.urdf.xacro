<?xml version="1.0"?>
<!--
  delivery_bot: differential-drive delivery robot for the social navigation project.

  Frame conventions (match these EXACTLY in the SolidWorks model later):
    - Every link frame: x forward, y left, z up.
    - base_footprint: on the ground, directly under the robot center. This is
      the frame the DiffDrive odometry and Nav2 use (robot_base_frame).
    - base_link: chassis geometric center, 0.14 m above ground.
    - Wheels: rotation axis along the link's local z after the -90deg roll,
      i.e. physically along +Y of the robot.

  Geometry is deliberately simple (boxes/cylinders). To swap in SolidWorks
  meshes later: replace ONLY the <visual> geometry with
  <mesh filename="package://delivery_bot_description/meshes/<link>.stl"/>
  and keep these primitive <collision> shapes.
-->
<robot name="delivery_bot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:include filename="macros.xacro"/>

  <!-- ================= Dimensions & masses ================= -->
  <xacro:property name="chassis_length"   value="0.50"/>
  <xacro:property name="chassis_width"    value="0.40"/>
  <xacro:property name="chassis_height"   value="0.20"/>
  <xacro:property name="chassis_mass"     value="12.0"/>
  <xacro:property name="base_z"           value="0.14"/>  <!-- base_link height above ground -->

  <xacro:property name="wheel_radius"     value="0.09"/>
  <xacro:property name="wheel_width"      value="0.04"/>
  <xacro:property name="wheel_mass"       value="1.0"/>
  <xacro:property name="wheel_separation" value="0.44"/>

  <xacro:property name="caster_radius"    value="0.045"/>
  <xacro:property name="caster_mass"      value="0.4"/>
  <xacro:property name="caster_x"         value="0.20"/>

  <xacro:property name="cargo_size"       value="0.34"/>
  <xacro:property name="cargo_height"     value="0.22"/>
  <xacro:property name="cargo_mass"       value="3.0"/>

  <xacro:property name="lidar_radius"     value="0.045"/>
  <xacro:property name="lidar_height"     value="0.05"/>
  <xacro:property name="lidar_mass"       value="0.2"/>

  <!-- ================= Materials ================= -->
  <material name="grey"><color rgba="0.55 0.57 0.60 1.0"/></material>
  <material name="dark_grey"><color rgba="0.15 0.15 0.15 1.0"/></material>
  <material name="orange"><color rgba="0.90 0.45 0.10 1.0"/></material>
  <material name="black"><color rgba="0.05 0.05 0.05 1.0"/></material>

  <!-- ================= base_footprint & chassis ================= -->
  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${base_z}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <geometry><box size="${chassis_length} ${chassis_width} ${chassis_height}"/></geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry><box size="${chassis_length} ${chassis_width} ${chassis_height}"/></geometry>
    </collision>
    <xacro:inertial_box mass="${chassis_mass}" x="${chassis_length}" y="${chassis_width}" z="${chassis_height}">
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertial_box>
  </link>

  <!-- ================= Drive wheels ================= -->
  <xacro:macro name="drive_wheel" params="prefix reflect">
    <link name="${prefix}_wheel_link">
      <visual>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <material name="dark_grey"/>
      </visual>
      <collision>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      </collision>
      <xacro:inertial_cylinder mass="${wheel_mass}" radius="${wheel_radius}" length="${wheel_width}">
        <origin xyz="0 0 0" rpy="0 0 0"/>
      </xacro:inertial_cylinder>
    </link>
    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel_link"/>
      <origin xyz="0 ${reflect * wheel_separation / 2.0} ${wheel_radius - base_z}"
              rpy="${-pi/2} 0 0"/>
      <axis xyz="0 0 1"/>
    </joint>
  </xacro:macro>

  <xacro:drive_wheel prefix="left"  reflect="1"/>
  <xacro:drive_wheel prefix="right" reflect="-1"/>

  <!-- ================= Casters (front & rear) ================= -->
  <xacro:macro name="caster" params="prefix x_pos">
    <link name="${prefix}_caster_link">
      <visual>
        <geometry><sphere radius="${caster_radius}"/></geometry>
        <material name="dark_grey"/>
      </visual>
      <collision>
        <geometry><sphere radius="${caster_radius}"/></geometry>
      </collision>
      <xacro:inertial_sphere mass="${caster_mass}" radius="${caster_radius}">
        <origin xyz="0 0 0" rpy="0 0 0"/>
      </xacro:inertial_sphere>
    </link>
    <joint name="${prefix}_caster_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${prefix}_caster_link"/>
      <origin xyz="${x_pos} 0 ${caster_radius - base_z}" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <xacro:caster prefix="front" x_pos="${caster_x}"/>
  <xacro:caster prefix="rear"  x_pos="${-caster_x}"/>

  <!-- ================= Cargo box ================= -->
  <link name="cargo_link">
    <visual>
      <geometry><box size="${cargo_size} ${cargo_size} ${cargo_height}"/></geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <geometry><box size="${cargo_size} ${cargo_size} ${cargo_height}"/></geometry>
    </collision>
    <xacro:inertial_box mass="${cargo_mass}" x="${cargo_size}" y="${cargo_size}" z="${cargo_height}">
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertial_box>
  </link>

  <joint name="cargo_joint" type="fixed">
    <parent link="base_link"/>
    <child link="cargo_link"/>
    <!-- sits on the chassis top: chassis top is at +0.10, cargo half-height 0.11 -->
    <origin xyz="0 0 ${chassis_height/2.0 + cargo_height/2.0}" rpy="0 0 0"/>
  </joint>

  <!-- ================= 2D lidar (360 deg, above the cargo) ================= -->
  <link name="lidar_link">
    <visual>
      <geometry><cylinder radius="${lidar_radius}" length="${lidar_height}"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry><cylinder radius="${lidar_radius}" length="${lidar_height}"/></geometry>
    </collision>
    <xacro:inertial_cylinder mass="${lidar_mass}" radius="${lidar_radius}" length="${lidar_height}">
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertial_cylinder>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <!-- cargo top at +0.32 rel base_link; lidar center 0.025 above that -->
    <origin xyz="0 0 ${chassis_height/2.0 + cargo_height + lidar_height/2.0}" rpy="0 0 0"/>
  </joint>

  <!-- ================= Front RGB-D camera ================= -->
  <link name="camera_link">
    <visual>
      <geometry><box size="0.03 0.09 0.03"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry><box size="0.03 0.09 0.03"/></geometry>
    </collision>
    <xacro:inertial_box mass="0.1" x="0.03" y="0.09" z="0.03">
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertial_box>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="${chassis_length/2.0 + 0.01} 0 0.05" rpy="0 0 0"/>
  </joint>

  <!-- Optical frame (z forward, x right) for image consumers like RViz -->
  <link name="camera_link_optical"/>
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_link_optical"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

  <!-- ================= IMU ================= -->
  <link name="imu_link">
    <visual>
      <geometry><box size="0.02 0.02 0.02"/></geometry>
      <material name="black"/>
    </visual>
    <xacro:inertial_box mass="0.05" x="0.02" y="0.02" z="0.02">
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertial_box>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>

  <!-- ================= Ignition Gazebo plugins & sensors ================= -->
  <xacro:include filename="gazebo.xacro"/>

</robot>
